# ─── WhatsApp Music Bot — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# Values here override config/config.json.

# Node environment
NODE_ENV=production

# Bot command prefix (default: .)
PREFIX=.

# Max audio duration in seconds (default: 300 = 5 minutes)
MAX_AUDIO_DURATION=300

# Your WhatsApp channel JID
# How to find it: Go to your channel in WhatsApp → Copy invite link
# The ID format is: 120363XXXXXXXXXXXXXXXXX@newsletter
CHANNEL_JID=120363XXXXXXXXXXXXXXXXX@newsletter

# Pairing-code login (optional)
# If set, the bot auto-requests a pairing code for this number on startup.
# Format: country code + number, digits only, no '+' (e.g. 14155552671)
# If left blank, open the web UI (http://localhost:3000) and enter it there instead.
PAIRING_PHONE_NUMBER=

# Web server port (for the pairing-code page)
PORT=3000
WEB_PORT=3000
